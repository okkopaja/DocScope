    "@docscope/shared-utils": "workspace:*",
    "@google/genai": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "rimraf": "^6.0.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  }
