{
  "name": "@docscope/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc --build",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test:unit": "vitest run",
    "test:api": "vitest run --config vitest.api.config.ts",
    "clean": "rimraf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@docscope/chunker": "workspace:*",
    "@docscope/db": "workspace:*",
    "@docscope/embeddings": "workspace:*",
    "@docscope/extractor": "workspace:*",
    "@docscope/retrieval": "workspace:*",
    "@docscope/security": "workspace:*",
    "@docscope/shared-types": "workspace:*",
    "@docscope/shared-utils": "workspace:*",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^5.0.1",
    "express-rate-limit": "^7.0.0",
    "helmet": "^8.0.0",
    "pino-http": "^10.0.0",
    "redis": "^5.11.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/supertest": "^6.0.0",
    "rimraf": "^6.0.0",
    "supertest": "^7.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  }
}
