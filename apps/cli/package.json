{
  "name": "@docscope/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "docscope": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc --build",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test:unit": "vitest run --reporter=verbose",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "clean": "rimraf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@docscope/chunker": "workspace:*",
    "@docscope/db": "workspace:*",
    "@docscope/embeddings": "workspace:*",
    "@docscope/extractor": "workspace:*",
    "@docscope/retrieval": "workspace:*",
    "@docscope/security": "workspace:*",
    "@docscope/shared-types": "workspace:*",
    "@docscope/shared-utils": "workspace:*",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "inquirer": "^12.0.0",
    "ora": "^8.0.0",
    "p-limit": "^7.3.0",
    "redis": "^5.11.0",
    "sharp": "^0.33.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "rimraf": "^6.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  }
}
